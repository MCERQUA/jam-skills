{
  "name": "remotion-video-project",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "render": "npx remotion render src/index.ts --codec h264 --crf 18",
    "render:fast": "npx remotion render src/index.ts --codec h264 --crf 23",
    "preview": "npx remotion preview src/index.ts",
    "voiceover": "node --strip-types generate-voiceover.ts",
    "optimize": "ffmpeg -y -i out/video.mp4 -c copy -movflags +faststart out/video-web.mp4"
  },
  "dependencies": {
    "@remotion/cli": "4.0.434",
    "@remotion/renderer": "4.0.434",
    "@remotion/transitions": "4.0.434",
    "@remotion/light-leaks": "4.0.434",
    "@remotion/media": "4.0.434",
    "@remotion/google-fonts": "4.0.434",
    "@remotion/shapes": "4.0.434",
    "@remotion/paths": "4.0.434",
    "@remotion/layout-utils": "4.0.434",
    "@remotion/noise": "4.0.434",
    "@remotion/captions": "4.0.434",
    "@remotion/lottie": "4.0.434",
    "@remotion/motion-blur": "4.0.434",
    "@remotion/gif": "4.0.434",
    "lottie-web": "^5.12.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.434"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0"
  }
}
