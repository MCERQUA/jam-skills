{
  "name": "remotion-video-project",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "render": "remotion render src/index.ts --codec h264 --crf 18",
    "render:fast": "remotion render src/index.ts --codec h264 --crf 23",
    "preview": "remotion preview src/index.ts",
    "voiceover": "node --strip-types generate-voiceover.ts",
    "optimize": "ffmpeg -y -i out/video.mp4 -c copy -movflags +faststart out/video-web.mp4"
  },
  "dependencies": {
    "@remotion/cli": "4.0.434",
    "@remotion/renderer": "4.0.434",
    "@remotion/transitions": "4.0.434",
    "@remotion/light-leaks": "4.0.434",
    "@remotion/media": "4.0.434",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.434"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0"
  }
}
