# Suno API Configuration for OpenClaw
# Frontend server URL - set this if your frontend is served from a different origin than the backend
# Leave empty to auto-detect from window.location.origin (correct for standard deploys)
# AGENT_SERVER_URL=https://your-domain.com

SUNO_API_KEY=5cb54e8b50a68333fee2ec9604de2e19
SUNO_CALLBACK_URL=https://devbot.mikecerqua.ca/api/suno/callback

# Default API base (official Suno API)
SUNO_API_BASE=https://api.sunoapi.org

# Output directory for generated music
SUNO_OUTPUT_DIR=/home/mike/WEBSITES/OpenVoiceUI/generated_music

# Default model: v5 (latest)
# Other options: v4, v4_5, v4_5PLUS, v4_5ALL
SUNO_MODEL=v5
